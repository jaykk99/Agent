# Gemini API key (required for AI chat)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub OAuth app credentials (required for GitHub sign-in / connect)
# Create at: https://github.com/settings/developers -> OAuth Apps
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Supabase project credentials
# Get from: https://supabase.com/dashboard -> Project -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Your deployed app URL (REQUIRED — used as the OAuth redirect base URL)
# Must exactly match the URL registered in each OAuth app
NEXTAUTH_URL=https://your-vercel-url.vercel.app

# Supabase Management API OAuth (for connecting Supabase as an integration)
# Create at: https://supabase.com/dashboard -> Account -> OAuth Apps
SUPABASE_OAUTH_CLIENT_ID=your_supabase_oauth_client_id
SUPABASE_OAUTH_CLIENT_SECRET=your_supabase_oauth_client_secret

# Vercel OAuth (for connecting Vercel as an integration)
# Create at: https://vercel.com/account/tokens -> OAuth Apps
VERCEL_OAUTH_CLIENT_ID=your_vercel_oauth_client_id
VERCEL_OAUTH_CLIENT_SECRET=your_vercel_oauth_client_secret
